rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function for admin checks
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.role == 'super_admin';
    }

    // Function to verify if user is a doctor
    function isDoctor() {
      return request.auth != null && request.auth.token.role == 'doctor';
    }

    match /kyc_documents/{userId}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isSuperAdmin();
    }

    match /medical_documents/{patientId}/{fileName} {
      // Patient can read their own medical documents
      allow read: if request.auth != null && request.auth.uid == patientId;
      // Doctors can read and upload medical documents for their patients
      allow read, write: if isDoctor() || isSuperAdmin();
      // Additional security: verify ownership via metadata if needed
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
