rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (request.auth.token.role == 'admin' || request.auth.token.role == 'super_admin');
    }

    // --- ICare Collections ---

    // Khung giờ khám (Slots)
    match /slots/{slotId} {
      // Cho phép đọc và ghi công khai để phục vụ việc Seed dữ liệu mẫu và chạy Kiosk
      allow read, write: if true;
    }

    // Lịch hẹn (Bookings)
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.patientId || isAdmin());
      allow create: if true; 
      allow update, delete: if isAdmin();
    }

    // Các quy tắc khác giữ nguyên...
    match /users/{userId} {
      allow read, update: if request.auth.uid == userId || isAdmin();
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /doctors/{doctorId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /hospitals/{hospitalId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /registered_phones/{phone} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /qr_tokens/{token} {
      allow read: if true;
      allow write, delete: if isSignedIn();
    }

    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
