rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to verify if user is a super admin
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.role == 'super_admin';
    }

    match /doctor_applications/{userId} {
      // Unverified Doctors can only read and create their own application securely
      allow read, create: if request.auth != null && request.auth.uid == userId;
      // Admins can read all applications for verification 
      allow read: if isSuperAdmin();
      // No updates directly from the client. Update must happen via Cloud Functions!
      allow update, delete: if false; 
    }

    match /verification_audit_logs/{logId} {
      // ONLY allow reading by admins.
      // NO WRITING ALLOWED FROM ANY CLIENT. (Written strictly by admin SDK in Cloud Functions).
      allow read: if isSuperAdmin();
      allow write: if false; 
    }
    
    // Add strict default deny for unmatched paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
